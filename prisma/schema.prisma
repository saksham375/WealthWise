datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  name           String
  passwordHash   String
  age            Int
  gender         String
  avatarPath     String?
  currencyCode   String   @default("INR")
  showCents      Boolean  @default(true)
  numberFormat   String   @default("indian")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  transactions         Transaction[]
  budgets              Budget[]
  goals                Goal[]
  subscriptions        Subscription[]
  notifications        Notification[]
  securityQuestions    SecurityQuestion[]
  sessions             Session[]
  loginAttempts        LoginAttempt[]
  groupMemberships     GroupMember[]
  paidExpenses         GroupExpense[]       @relation("Payer")
  expenseSplits        GroupExpenseSplit[]
  settlements          Settlement[]         @relation("Settler")
  settlementsReceived  Settlement[]         @relation("Receiver")
  bugReports           BugReport[]
}

model SecurityQuestion {
  id           String   @id @default(uuid())
  userId       String
  questionText String
  answerHash   String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginAttempt {
  id        String   @id @default(uuid())
  userId    String?
  email     String
  ipAddress String
  success   Boolean
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Category {
  id        String        @id @default(uuid())
  userId    String?
  name      String
  type      String
  iconName  String
  color     String
  isSystem  Boolean       @default(false)
  budget    Float?
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())

  transactions      Transaction[]
  budgets           Budget[]
  recurringSchedules RecurringSchedule[]

  @@index([userId, isSystem])
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String
  categoryId  String
  amount      Float
  type        String
  description String?
  timestamp   DateTime @default(now())
  isRecurring Boolean  @default(false)
  recurringId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  Category           @relation(fields: [categoryId], references: [id])
  recurring RecurringSchedule? @relation(fields: [recurringId], references: [id])

  @@index([userId, timestamp])
  @@index([userId, type, timestamp])
}

model RecurringSchedule {
  id            String        @id @default(uuid())
  userId        String
  templateTitle String
  amount        Float
  type          String
  categoryId    String
  frequency     String
  nextRunDate   DateTime
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())

  transactions Transaction[]
  category     Category       @relation(fields: [categoryId], references: [id])
}

model Budget {
  id              String   @id @default(uuid())
  userId          String
  categoryId      String
  limitAmount     Float
  month           Int
  year            Int
  applyEveryMonth Boolean  @default(false)
  alertSent80     Boolean  @default(false)
  alertSent100    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId, month, year])
  @@index([userId])
}

model Goal {
  id            String             @id @default(uuid())
  userId        String
  goalName      String
  emoji         String             @default("🎯")
  targetAmount  Float
  currentSaved  Float              @default(0)
  deadline      DateTime
  isCompleted   Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions GoalContribution[]

  @@index([userId])
}

model GoalContribution {
  id        String   @id @default(uuid())
  goalId    String
  amount    Float
  note      String?
  createdAt DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model Subscription {
  id            String   @id @default(uuid())
  userId        String
  serviceName   String
  emoji         String   @default("🔁")
  amount        Float
  billingCycle  String
  nextDueDate   DateTime
  lastPaidDate  DateTime?
  status        String   @default("ACTIVE")
  transactionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Group {
  id          String         @id @default(uuid())
  groupName   String
  emoji       String         @default("👥")
  createdById String
  createdAt   DateTime       @default(now())

  members     GroupMember[]
  expenses    GroupExpense[]
  settlements Settlement[]
}

model GroupMember {
  id      String @id @default(uuid())
  groupId String
  userId  String
  role    String @default("MEMBER")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model GroupExpense {
  id          String              @id @default(uuid())
  groupId     String
  payerId     String
  description String
  totalAmount Float
  date        DateTime
  splitMethod String
  createdAt   DateTime            @default(now())

  group  Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer  User                 @relation("Payer", fields: [payerId], references: [id])
  splits GroupExpenseSplit[]
}

model GroupExpenseSplit {
  id         String       @id @default(uuid())
  expenseId  String
  userId     String
  amount     Float
  percentage Float?
  isSettled  Boolean      @default(false)

  expense GroupExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id])
}

model Settlement {
  id              String   @id @default(uuid())
  groupId         String
  settlerUserId   String
  receiverUserId  String
  amount          Float
  method          String
  createdAt       DateTime @default(now())

  group    Group @relation(fields: [groupId], references: [id])
  settler  User  @relation("Settler", fields: [settlerUserId], references: [id])
  receiver User  @relation("Receiver", fields: [receiverUserId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BugReport {
  id              String   @id @default(uuid())
  userId          String
  title           String
  description     String
  severity        String
  screenshotPath  String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
